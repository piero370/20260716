local function clearActiveConnections()
    for _, conn in ipairs(activeConnections) do
        if conn then
            conn:Disconnect()
        end
    end
    table.clear(activeConnections)
end

-- 【修正】離脱時に勢い（慣性）を乗せるため、最後の速度を引数で受け取れるように変更
local function releaseCharacter(keepVelocity)
	if syncConnection then
		syncConnection:Disconnect()
		syncConnection = nil
	end
	
	if currentBoundModel then
		currentBoundModel:SetAttribute("IsOccupied", nil)
		currentBoundModel = nil
	end
	
	local character = player.Character
	if character then
		local hrp = character:FindFirstChild("HumanoidRootPart")
		local humanoid = character:FindFirstChildOfClass("Humanoid")
		
		if humanoid then
			humanoid.PlatformStand = false
		end
		
		if hrp then
			if keepVelocity then
				-- 解除時の不自然さをなくすため、直前まで出ていた速度をキャラクターの物理体にそのまま適用
				hrp.AssemblyLinearVelocity = keepVelocity
			else
				hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
			end
			hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
		end
	end
	
	isCurrentlyStuck = false
	relativeX = 0
	relativeZ = 0
end

-- [他人に掴まれている状態の判定]
local function checkIfGrabbed()
    local character = player.Character
    if not character then return false end

    -- 1. 物理Joint（Weldなど）による厳格チェック
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if hrp then
        for _, obj in ipairs(hrp:GetChildren()) do
            if obj:IsA("Weld") or obj:IsA("WeldConstraint") or obj:IsA("ManualWeld") or obj:IsA("BallSocketConstraint") then
                local part0 = obj.Part0
                local part1 = obj.Part1
                local otherPart = (part0 == hrp) and part1 or part0
                
                if otherPart and otherPart:IsDescendantOf(workspace) and not otherPart:IsDescendantOf(character) then
                    local otherModel = otherPart:FindFirstAncestorOfClass("Model")
                    if otherModel and otherModel:FindFirstChild("Humanoid") and otherModel ~= character then
                        return true
                    end
                end
            end
        end
    end

    -- 2. キャラクター内の特定属性（フォルダや値）の検知
    for _, obj in ipairs(character:GetDescendants()) do
        local nameLower = string.lower(obj.Name)
        if nameLower == "grabbed" or nameLower == "carried" or nameLower == "holder" or nameLower == "grab" or nameLower == "welded" then
            if not obj:IsDescendantOf(workspace) or obj:FindFirstAncestor(player.Name) then
                return true
            end
        end
    end

    return false
end

-- [強制解除トリガー] 本当に拘束されている時だけ安全に発動
local function triggerForcedRelease()
    if isCurrentlyStuck or syncConnection then
        releaseCharacter()
        
        AntiStuckConfig.IsPaused = true
        
        OrionLib:MakeNotification({
            Name = '掴まれ・投げられ検知',
            Content = '他プレイヤーによる掴みを検知したため、吸着を一時オフにします。',
            Time = 3,
        })
        
        task.delay(3, function()
            AntiStuckConfig.IsPaused = false
        end)
    end
end

