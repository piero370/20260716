local function bringPalletToMe()
    local character = player.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local found = false
    for _, desc in ipairs(workspace:GetDescendants()) do
        if desc:IsA("Model") and desc.Name == targetModelName then
            local basePart = desc:WaitForChild("Main", 5) or desc.PrimaryPart or desc:FindFirstChildWhichIsA("BasePart", true)
            if basePart then
                basePart.CFrame = hrp.CFrame * CFrame.new(0, 2, -6)
                found = true
                OrionLib:MakeNotification({
                    Name = 'demon',
                    Content = 'kabeana demon',
                    Time = 3,
                })
                break
            end
        end
    end

    if not found then
        OrionLib:MakeNotification({
            Name = 'kabeana',
            Content = 'マップ内に板が見つかりませんでした。',
            Time = 3,
        })
    end
end

local function togglePalletSystem(forceState)
    local targetState = (forceState ~= nil) and forceState or (not systemEnabled)
    systemEnabled = targetState
    if palletToggle then palletToggle:Set(systemEnabled) end
    if not systemEnabled and isCurrentlyStuck then releaseCharacter() end
end

local function toggleGrabSystem(forceState)
    local targetState = (forceState ~= nil) and forceState or (not GrabConfig.Enabled)
    GrabConfig.Enabled = targetState
    if grabToggle then grabToggle:Set(GrabConfig.Enabled) end
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	
	if input.KeyCode == palletBindKey then
		if isCurrentlyStuck then
			releaseCharacter()
			togglePalletSystem(false)
		else
			togglePalletSystem()
		end
	end

    if input.KeyCode == GrabConfig.BindKey then
        toggleGrabSystem()
    end
end)

