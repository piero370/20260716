local ReplicatedStorage = game:GetService("ReplicatedStorage")

local function setupGrabEventsHook()
    local grabEvents = ReplicatedStorage:FindFirstChild("GrabEvents")
    
    if grabEvents then
        local function connectRemote(remote)
            remote.OnClientEvent:Connect(function(...)
                local args = {...}
                local isTriggeredByMe = false
                local isTargetingMe = false
                
                pcall(function()
                    local char = player.Character
                    
                    local sender = args[1]
                    if sender == player or sender == char then
                        isTriggeredByMe = true
                    end
                    
                    for i = 2, #args do
                        local arg = args[i]
                        if arg == player or arg == char or (typeof(arg) == "Instance" and char and arg:IsDescendantOf(char)) then
                            isTargetingMe = true
                            break
                        end
                    end
                end)
                
                if isTriggeredByMe then 
                    return 
                end
                
                if isTargetingMe or checkIfGrabbed() then
                    triggerForcedRelease()
                end
            end)
        end

        if grabEvents:IsA("RemoteEvent") then
            connectRemote(grabEvents)
            print("--- GrabEventsリモートのダブルフィルター監視をセットしました ---")
        else
            for _, child in ipairs(grabEvents:GetDescendants()) do
                if child:IsA("RemoteEvent") then
                    connectRemote(child)
                end
            end
            
            grabEvents.DescendantAdded:Connect(function(child)
                if child:IsA("RemoteEvent") then
                    connectRemote(child)
                end
            end)
        end
    end
end

task.spawn(setupGrabEventsHook)
ReplicatedStorage.ChildAdded:Connect(function(child)
    if child.Name == "GrabEvents" then
        task.wait(0.1)
        setupGrabEventsHook()
    end
end)

