local function setupPalletConnection(character)
    clearActiveConnections()

	local hrp = character:WaitForChild("HumanoidRootPart", 5)
	local humanoid = character:WaitForChild("Humanoid", 5)
	if not hrp or not humanoid then return end

	local function checkAndBind(desc)
		if desc:IsA("Model") and desc.Name == targetModelName then
			local basePart = desc:WaitForChild("Main", 5) or desc.PrimaryPart or desc:FindFirstChildWhichIsA("BasePart", true)
			if basePart then
				for _, child in ipairs(desc:GetDescendants()) do
					if child:IsA("BasePart") then
						local touchConn = child.Touched:Connect(function(hit)
							if not systemEnabled then return end
                            if AntiStuckConfig.IsPaused then return end 
							if isCurrentlyStuck then return end
							if desc:GetAttribute("IsOccupied") == true then return end
							
							if hit:IsDescendantOf(character) then
                                if checkIfGrabbed() then return end

								isCurrentlyStuck = true
								currentBoundModel = desc
								desc:SetAttribute("IsOccupied", true)
								
								humanoid.PlatformStand = false
								
								local initialRelativePos = basePart.CFrame:PointToObjectSpace(hrp.Position)
								relativeX = math.clamp(initialRelativePos.X, -6, 6)
								relativeZ = math.clamp(initialRelativePos.Z, -6, 6)
								
								local lastPosition = basePart.Position
                                local currentVelocity = Vector3.new(0, 0, 0)
								
								syncConnection = RunService.Heartbeat:Connect(function(deltaTime)
									if character and hrp and basePart and basePart:IsDescendantOf(workspace) and humanoid.Health > 0 then
                                        
                                        if checkIfGrabbed() then
                                            triggerForcedRelease()
                                            return
                                        end

										local currentPosition = basePart.Position
										local calculatedVelocity = (currentPosition - lastPosition) / deltaTime
										lastPosition = currentPosition
										
										local moveDirection = humanoid.MoveDirection
										
										if moveDirection.Magnitude > 0 then
											local localMove = basePart.CFrame:VectorToObjectSpace(moveDirection * (humanoid.WalkSpeed * speedMultiplier) * deltaTime)
											relativeX = math.clamp(relativeX + localMove.X, -6, 6)
											relativeZ = math.clamp(relativeZ + localMove.Z, -6, 6)
										end
										
										local cameraLook = camera.CFrame.LookVector
										local cameraYAngle = math.atan2(-cameraLook.X, -cameraLook.Z)
										
										local targetCFrame = basePart.CFrame * CFrame.new(relativeX, 4.5, relativeZ)
										hrp.CFrame = CFrame.new(targetCFrame.Position) * CFrame.fromEulerAnglesXYZ(0, cameraYAngle, 0)
										
										local walkVelocity = moveDirection * (humanoid.WalkSpeed * speedMultiplier)
                                        -- ループ中に毎フレームの最新速度をローカルに保持
                                        currentVelocity = (calculatedVelocity * speedMultiplier) + Vector3.new(walkVelocity.X, 0, walkVelocity.Z)
										
                                        hrp.AssemblyLinearVelocity = currentVelocity
										hrp.AssemblyAngularVelocity = basePart.AssemblyAngularVelocity
										
										local dist = (hrp.Position - basePart.Position).Magnitude
										if dist > 15 then
											releaseCharacter(currentVelocity)
										end
									else
										releaseCharacter()
									end
								end)
							end
						end)
                        table.insert(activeConnections, touchConn)

                        -- 自分の板・少しの段差は完全にスルーし、激突時に慣性を適用する壁判定
                        local wallConn = child.Touched:Connect(function(hit)
                            if not AntiStuckConfig.Enabled then return end
                            if AntiStuckConfig.IsPaused then return end
                            if not isCurrentlyStuck then return end
                            if currentBoundModel ~= desc then return end 

                            if hit:IsDescendantOf(character) or hit:IsDescendantOf(desc) then 
                                return 
                            end

                            if hit.Name ~= "Baseplate" and hit.Name ~= "Terrain" then
                                local rayOrigin = child.Position
                                local rayDirection = (hit.Position - child.Position).Unit * 5
                                local varParams = RaycastParams.new()
                                
                                varParams.FilterDescendantsInstances = {character, desc}
                                varParams.FilterType = Enum.RaycastFilterType.Exclude

                                local result = workspace:Raycast(rayOrigin, rayDirection, varParams)
                                local isWall = false
                                if result then
                                    if math.abs(result.Normal.Y) < 0.3 then
                                        isWall = true
                                    end
                                else
                                    if hit.Size.Y > 4 and hit.Size.X > 1 then
                                        isWall = true
                                    end
                                end

                                if isWall then
                                    -- 衝突時のプレイヤーの直近の移動速度を取得
                                    local currentVelocity = hrp.AssemblyLinearVelocity
                                    
                                    -- 【物理ふっとび】直近の勢いをキープしてリリースする
                                    releaseCharacter(currentVelocity)
                                    AntiStuckConfig.IsPaused = true
                                    
                                    OrionLib:MakeNotification({
                                        Name = 'Anti-Stuck (壁接触)',
                                        Content = '壁に衝突したため離脱しました。1.5秒後に再吸着可能になります。',
                                        Time = 1,
                                    })
                                    
                                    task.delay(1.5, function()
                                        AntiStuckConfig.IsPaused = false
                                    end)
                                end
                            end
                        end)
                        table.insert(activeConnections, wallConn)
					end
				end
			end
		end
	end

	for _, desc in ipairs(workspace:GetDescendants()) do
		checkAndBind(desc)
	end
    
    local addedConn = workspace.DescendantAdded:Connect(checkAndBind)
    table.insert(activeConnections, addedConn)
end

-- 自動掴みループ
RunService.RenderStepped:Connect(function()
    if not GrabConfig.Enabled or not GrabConfig.CanClick then return end
    local character = player.Character
    if not character then return end
    
    local size = camera.ViewportSize
    local ray = camera:ViewportPointToRay(size.X / 2, size.Y / 2)
    
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {character}
    params.FilterType = Enum.RaycastFilterType.Exclude
    
    local result = workspace:Raycast(ray.Origin, ray.Direction * GrabConfig.Range, params)
    
    if result and result.Instance then
        local hit = result.Instance
        local model = hit:FindFirstAncestorOfClass("Model")
        
        if model and model:FindFirstChild("Humanoid") and model ~= character then
            GrabConfig.CanClick = false
            
            VIM:SendMouseButtonEvent(size.X / 2, size.Y / 2, 0, true, game, 0)
            task.wait(0.02)
            VIM:SendMouseButtonEvent(size.X / 2, size.Y / 2, 0, false, game, 0)
            
            task.delay(GrabConfig.CoolTime, function()
                GrabConfig.CanClick = true
            end)
        end
    end
end)

-- キャラクタースポーン・リセット処理
local function onCharacterAdded(char)
    releaseCharacter()
    clearActiveConnections()
    AntiStuckConfig.IsPaused = false
    isCurrentlyStuck = false
    currentBoundModel = nil
    
    local humanoid = char:WaitForChild("Humanoid", 5)
    if humanoid then
        humanoid.Died:Connect(function()
            releaseCharacter()
            clearActiveConnections()
            AntiStuckConfig.IsPaused = false
            isCurrentlyStuck = false
            currentBoundModel = nil
        end)
    end
    
    task.spawn(setupPalletConnection, char)
end

